    "switchScript": "(function(){ if (typeof jQuery === 'undefined') return; var targetVal = '{{TARGET_YEAR}}-{{TARGET_SEM}}'; if (window.aeustQueryLock && (Date.now() - window.aeustQueryLock < 3000)) return; try { var selectEl = document.querySelector('select[name=\"semester\"], select#sms'); if (!selectEl) return; var currentVal = selectEl.value; if (currentVal !== targetVal) { window.aeustQueryLock = Date.now(); selectEl.value = targetVal; selectEl.dispatchEvent(new Event('change')); setTimeout(function() { var qBtn = document.querySelector('button.query-btn, #btnQuery, input[type=\"submit\"]'); if (qBtn) qBtn.click(); }, 800); } } catch(e) {} })();",
    "parseScript": "(function() { if (window._hasSentData) return; var container = document.querySelector('.StdCosTable_T_Box'); if (!container) return; var divs = Array.from(container.children).filter(function(d) { return d.id && (d.id.indexOf('CELL_') === 0 || d.id.indexOf('COSTIME_') === 0); }); if (divs.length === 0) return; window._hasSentData = true; var result = []; var srcMap = [2, 3, 4, 5, 6, 7, 1]; for (var i = 0; i < divs.length; i += 8) { var chunk = divs.slice(i, i + 8); if (chunk.length < 8) break; var slotText = chunk[0].innerText.trim(); var slotMatch = slotText.match(/第(\\d+)節/); var slot = slotMatch ? slotMatch[1] : slotText.split('\\n')[0].trim(); var days = []; for (var j = 0; j < 7; j++) { var cell = chunk[srcMap[j]]; var text = cell.innerText.trim(); if (cell.id.indexOf('COSTIME_') === 0 && text.length > 0) { var parts = text.split('\\n'); days.push({ name: parts[0] ? parts[0].trim() : text, teacher: parts[1] ? parts[1].trim() : '', room: parts[2] ? parts[2].trim() : '' }); } else { days.push({}); } } result.push({ slot: slot, days: days }); } if (result.length > 0) { if (window.mobileApp) window.mobileApp.postMessage({ detail: { type: 'DATA_SUCCESS', payload: result }}); } else { window._hasSentData = false; } })();",
